{
  "mcpServers": {
    "eic-xrootd-mcp-server": {
      "command": "/opt/local/bin/xrootd-mcp-server",
      "env": {
        "XROOTD_SERVER": "root://dtn-eic.jlab.org"
      }
    },
    "eic-zenodo-mcp-server": {
      "command": "/opt/local/bin/zenodo-mcp-server",
      "env": {
        "ZENODO_BASE_URL": "https://zenodo.org"
      }
    }
  }
}
